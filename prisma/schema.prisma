generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum LessonStatus {
  FREE
  RESERVED
  PAID
  IN_PROGRESS
  DONE
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  passwordHash String
  contacts     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students     Student[]
  groups       Group[]
  courses      Course[]
  lessons      Lesson[]
}

model Student {
  id        Int      @id @default(autoincrement())
  fullName  String
  userId    Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  lessons   Lesson[]
  groups    GroupMember[]
}

model Group {
  id        Int      @id @default(autoincrement())
  title     String
  userId    Int
  createdAt DateTime @default(now())

  user      User         @relation(fields: [userId], references: [id])
  members   GroupMember[]
  lessons   Lesson[]
}

model GroupMember {
  id        Int     @id @default(autoincrement())
  groupId   Int
  studentId Int

  group     Group   @relation(fields: [groupId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([groupId, studentId])
}

model Course {
  id         Int      @id @default(autoincrement())
  title      String
  targetName String?
  userId     Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  lessons    Lesson[]
}

model Lesson {
  id         Int          @id @default(autoincrement())
  title      String
  targetName String?
  status     LessonStatus @default(FREE)

  startAt    DateTime
  endAt      DateTime

  isPaid     Boolean      @default(false)
  linkUrl    String?

  userId     Int
  studentId  Int?
  groupId    Int?
  courseId   Int?

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user       User         @relation(fields: [userId], references: [id])
  student    Student?     @relation(fields: [studentId], references: [id])
  group      Group?       @relation(fields: [groupId], references: [id])
  course     Course?      @relation(fields: [courseId], references: [id])
}